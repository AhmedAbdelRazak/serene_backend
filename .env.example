# Core
PORT=8101
DATABASE=mongodb+srv://user:pass@cluster/dbname
CLIENT_URL=https://your-store-domain.com
SERVER_URL=https://api.your-store-domain.com
API_BASE_URL=https://api.your-store-domain.com
NODE_ENV=production

# Auth
JWT_SECRET=replace_me
JWT_RESET_PASSWORD=replace_me
MASTER_PASSWORD=replace_me
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me

# Email / SMS
SENDGRID_API_KEY=replace_me
SERENEJANNAT_ADMIN_EMAIL=owner@your-domain.com
SERENEJANNAT_ADMIN_EMAIL_CC=
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Payments
STRIPE_SECRET_KEY=replace_me
STRIPE_TEST_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
PAYPAL_CLIENT_ID_SANDBOX=replace_me
PAYPAL_SECRET_KEY_SANDBOX=replace_me
PAYPAL_CLIENT_ID_LIVE=replace_me
PAYPAL_SECRET_KEY_LIVE=replace_me
